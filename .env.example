# Slack Configuration (Phase 0 - required)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-1-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Slack Channel Configuration (Phase 2 - retrieval)
# Comma-separated list of Slack channel IDs to search for evidence
GRANTPROOF_CHANNEL_IDS=C123456,C789012

# Google Sheets/Drive Integration (Phase 1 - required now)
# Local dev: a file path to the service account JSON key.
GOOGLE_APPLICATION_CREDENTIALS=./slack/service-account.json
# Deployed hosts (e.g. Railway) with no writable secret-file mount: paste the
# full contents of the service account JSON key here instead. If both this
# and GOOGLE_APPLICATION_CREDENTIALS are set, this one wins. See src/google/auth.ts.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...", ...}
GRANTPROOF_SHEET_ID=your-sheet-id-from-the-url-here

# Google Drive Integration (Phase 4 - required for session_photos evidence)
GRANTPROOF_DRIVE_FOLDER_ID=your-drive-folder-id-from-the-url-here

# Gemini API Integration (Phase 2 - required for extraction)
GOOGLE_API_KEY=your-google-api-key-here

# Database Configuration (Phase 1 - required now)
# Local dev: a relative path is fine. On a deployed host, this must point at
# a mounted persistent volume (e.g. /data/grantproof.db) — container
# filesystems are otherwise ephemeral and the DB would reset on every redeploy.
DATABASE_PATH=./grantproof.db
